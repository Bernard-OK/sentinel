# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Database (Postgres + pgvector) ---
# Local dev default; adjust to your setup
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel

# --- Observability (Langfuse) ---
# Free cloud tier at https://cloud.langfuse.com — optional for Day 1
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Data sources ---
# NVD works without a key but is rate-limited; a free key raises the limit:
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# GitHub token for the Security Advisories GraphQL API (free, classic PAT, no scopes needed for public data)
GITHUB_TOKEN=

# --- Models (override defaults if desired) ---
GEN_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-haiku-4-5-20251001
EMBED_MODEL=BAAI/bge-large-en-v1.5
